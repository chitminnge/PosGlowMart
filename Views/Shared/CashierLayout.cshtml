<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - GlowMart POS</title>
    <link rel="stylesheet" href="~/css/CashierPanel.css" />
    <script src="~/js/cashier.js"></script>
</head>
<body>
    <!-- Navigation -->
    @Html.Partial("_CashierHeader")

    <div class="main-container">
        <!-- Categories (slide panel) -->
        <aside class="categories">
        
            @RenderSection("Categories", required: false)
        </aside>

        <!-- Scanner -->
        <aside class="scanner">
            @RenderSection("Scanner", required: false)
        </aside>

        <!-- Cart -->
        <main class="sale">
            @RenderBody()
        </main>
    </div>

    <!-- Pay section -->
    <footer>
        <p>Total: @RenderSection("Total", required: false)</p>
    </footer>
</body>
</html>
