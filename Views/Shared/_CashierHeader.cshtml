<div class="global-pos-header">
    <div class="header-brand">
        <i class="fas fa-spa"></i>
        <h2>GlowMart</h2>
        <span class="tagline">✨Skincare & Beauty Shop</span>
    </div>
    <div class="header-status">
        <div class="language-switch">
            <button id="myLangBtn" class="lang-btn active" onclick="switchLanguage('my')">
                <i class="fas fa-flag"></i> မြန်မာ
            </button>
            <button id="enLangBtn" class="lang-btn" onclick="switchLanguage('en')">
                <i class="fas fa-flag-usa"></i> English
            </button>
        </div>
        <div class="cashier-avatar" id="cashierAvatarBtn">
            <i class="fas fa-user-circle"></i>
            <span id="cashierNameDisplay">Cashier</span>
            <i class="fas fa-chevron-down"></i>
        </div>
    </div>
</div>