@model GlowMart.Models.ViewModels.CashShiftViewModel

@{
    ViewData["Title"] = "Open Shift";
}

<h2>Open Shift</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-action="Opening" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="StoreId" />
    <input type="hidden" asp-for="StaffId" />

    <div class="form-group">
        <label asp-for="OpeningBalance" class="control-label"></label>
        <input asp-for="OpeningBalance" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="OpeningBalance" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Open Shift</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
