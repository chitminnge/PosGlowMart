@{
    ViewData["Title"] = "Change Password";
}

<h2>Change Password</h2>

<form asp-controller="Staff"
      asp-action="ChangePassword"
      method="post">

    <div>
        <label>Username</label>
        <input type="text"
               name="username"
               class="form-control"
               required />
    </div>

    <br />

    <div>
        <label>Old Password</label>
        <input type="password"
               name="oldPassword"
               class="form-control"
               required />
    </div>

    <br />

    <div>
        <label>New Password</label>
        <input type="password"
               name="newPassword"
               class="form-control"
               required />
    </div>

    <br />

    <button type="submit"
            class="btn btn-primary">
        Change Password
    </button>
</form>

<br />

@if (ViewBag.Message != null)
{
    <div class="alert alert-success">
        @ViewBag.Message
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}